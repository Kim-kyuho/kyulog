   <Row><Cell><Data ss:Type="String">SCR-BLOG-LIST</Data></Cell><Cell><Data ss:Type="String">목록 영역</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">제목, 작성일, 카테고리, 요약, 태그</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">카드 클릭 시 상세 페이지 이동</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">관리자에게만 delete 버튼 표시</Data></Cell></Row>
