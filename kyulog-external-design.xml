   <Row><Cell><Data ss:Type="String">SCR-BLOG-EDIT</Data></Cell><Cell><Data ss:Type="String">/blog/edit/[id]</Data></Cell><Cell><Data ss:Type="String">관리자</Data></Cell><Cell><Data ss:Type="String">동적</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기존 글 수정 화면. 초기값 로드 후 편집</Data></Cell></Row>
