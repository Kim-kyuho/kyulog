 <Worksheet ss:Name="Auth">
  <Table>
   <Column ss:Width="180"/>
   <Column ss:Width="520"/>
   <Row>
    <Cell ss:StyleID="Header"><Data ss:Type="String">항목</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">내용</Data></Cell>
   </Row>
   <Row><Cell><Data ss:Type="String">인증 방식</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">NextAuth GitHubProvider 사용</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">필요 환경변수</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">GITHUB_ID, GITHUB_SECRET, NEXTAUTH_SECRET, DATABASE_URL, GITHUB_TOKEN, REPO_OWNER, REPO_NAME</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">세션 확장값</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">session.user.login, session.user.isAdmin</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">관리자 판정</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">GitHub 로그인 ID가 Kim-kyuho일 경우 token.isAdmin = true</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">비로그인 시 UI</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">헤더에서 Sign in 버튼 표시</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">로그인 시 UI</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">Hi, {login or name}, Admin/Viewer 표시, Logout 버튼 표시</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">관리자 페이지 접근</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">/blog/write, /blog/edit/[id] 진입 시 getAdminSession 검사. 실패 시 /blog 리다이렉트</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">관리자 API 접근</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">/api/write, /api/update, /api/delete, /api/upload-image 에서 getAdminSession 검사. 실패 시 401 반환</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">노출 제어</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">블로그 목록의 delete / new post, 상세의 edit 버튼은 관리자 세션일 때만 표시</Data></Cell></Row>
  </Table>
