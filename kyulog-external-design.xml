  </Table>
 </Worksheet>

 <Worksheet ss:Name="API">
  <Table>
   <Column ss:Width="80"/>
   <Column ss:Width="180"/>
   <Column ss:Width="110"/>
   <Column ss:Width="150"/>
   <Column ss:Width="240"/>
   <Column ss:Width="240"/>
   <Column ss:Width="220"/>
   <Row>
    <Cell ss:StyleID="Header"><Data ss:Type="String">API ID</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">경로</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Method</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">권한</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">요청</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">응답</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">설명</Data></Cell>
   </Row>
   <Row><Cell><Data ss:Type="String">API-001</Data></Cell><Cell><Data ss:Type="String">/api/post</Data></Cell><Cell><Data ss:Type="String">GET</Data></Cell><Cell><Data ss:Type="String">전체</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">없음</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">[{ id, title, date, category, tags, summary }]</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">블로그 목록 조회</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">API-002</Data></Cell><Cell><Data ss:Type="String">/api/write</Data></Cell><Cell><Data ss:Type="String">POST</Data></Cell><Cell><Data ss:Type="String">관리자</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">{ title, summary, content, category, tags }</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">201 { message: "Success" } / 400 / 401 / 500</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">새 글 등록. title/summary/content 필수</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">API-003</Data></Cell><Cell><Data ss:Type="String">/api/update</Data></Cell><Cell><Data ss:Type="String">POST</Data></Cell><Cell><Data ss:Type="String">관리자</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">{ id, title, summary, category, tags, content }</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">200 { message } / 400 / 401 / 404 / 500</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">기존 글 수정</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">API-004</Data></Cell><Cell><Data ss:Type="String">/api/delete</Data></Cell><Cell><Data ss:Type="String">POST</Data></Cell><Cell><Data ss:Type="String">관리자</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">{ id }</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">200 { message } / 400 / 401 / 500</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">글 삭제</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">API-005</Data></Cell><Cell><Data ss:Type="String">/api/upload-image</Data></Cell><Cell><Data ss:Type="String">POST</Data></Cell><Cell><Data ss:Type="String">관리자</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">multipart/form-data file=image/*, max 5MB</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">200 { url, redirectTo } / 400 / 401 / 500</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">GitHub Contents API를 사용해 public/blog-images에 업로드</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">API-006</Data></Cell><Cell><Data ss:Type="String">/api/auth/[...nextauth]</Data></Cell><Cell><Data ss:Type="String">GET, POST</Data></Cell><Cell><Data ss:Type="String">전체</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">NextAuth 내부 처리</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">세션, 로그인/로그아웃 리다이렉트</Data></Cell><Cell ss:StyleID="Wrap"><Data ss:Type="String">GitHub OAuth 인증 엔드포인트</Data></Cell></Row>
  </Table>
 </Worksheet>

